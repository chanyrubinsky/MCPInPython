{
  "manifest_version": 3,
  "name": "Mail Style Assistant",
  "version": "1.2",
  "description": "MCP letter extension for Gmail",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:5678/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sidebar.html",
        "sidebar.js",
        "sidebar.css"
      ],
      "matches": ["https://mail.google.com/*"],
      "use_dynamic_url": true
    }
  ]
}